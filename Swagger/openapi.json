{
  "openapi": "3.0.3",
  "info": {
    "title": "API Cadastro Auto Escola - Controle de Gastos",
    "version": "1.0.0",
    "description": "API para login e controle de gastos dos veiculos da auto escola."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    {
      "name": "Login"
    },
    {
      "name": "Gastos"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "tags": ["Login"],
        "summary": "Realiza o login do usuario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "username": "admin",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso"
          },
          "401": {
            "description": "Credenciais invalidas"
          }
        }
      }
    },
    "/gastos": {
      "get": {
        "tags": ["Gastos"],
        "summary": "Lista os gastos cadastrados",
        "responses": {
          "200": {
            "description": "Lista retornada com sucesso"
          }
        }
      },
      "post": {
        "tags": ["Gastos"],
        "summary": "Cria um novo gasto do veiculo",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GastoRequest"
              },
              "example": {
                "veiculoId": "CAR-002",
                "tipo": "oleo",
                "valor": 189.9,
                "data": "2026-04-10",
                "descricao": "Troca de oleo e filtro"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Gasto criado com sucesso"
          },
          "400": {
            "description": "Dados obrigatorios ausentes"
          }
        }
      }
    },
    "/gastos/{id}": {
      "get": {
        "tags": ["Gastos"],
        "summary": "Busca um gasto por id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Gasto encontrado"
          },
          "404": {
            "description": "Gasto nao encontrado"
          }
        }
      },
      "put": {
        "tags": ["Gastos"],
        "summary": "Atualiza um gasto por id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GastoUpdateRequest"
              },
              "example": {
                "valor": 210,
                "descricao": "Ajuste do valor da troca de oleo"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Gasto atualizado com sucesso"
          },
          "404": {
            "description": "Gasto nao encontrado"
          }
        }
      },
      "delete": {
        "tags": ["Gastos"],
        "summary": "Remove um gasto por id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Gasto removido com sucesso"
          },
          "404": {
            "description": "Gasto nao encontrado"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "GastoRequest": {
        "type": "object",
        "required": ["veiculoId", "tipo", "valor", "data"],
        "properties": {
          "veiculoId": {
            "type": "string"
          },
          "tipo": {
            "type": "string",
            "enum": ["oleo", "combustivel", "lavagem", "pastilha_freio", "velas"]
          },
          "valor": {
            "type": "number"
          },
          "data": {
            "type": "string",
            "format": "date"
          },
          "descricao": {
            "type": "string"
          }
        }
      },
      "GastoUpdateRequest": {
        "type": "object",
        "properties": {
          "veiculoId": {
            "type": "string"
          },
          "tipo": {
            "type": "string"
          },
          "valor": {
            "type": "number"
          },
          "data": {
            "type": "string",
            "format": "date"
          },
          "descricao": {
            "type": "string"
          }
        }
      }
    }
  }
}
